# Server
PORT=8080
ENV=development

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/proply?sslmode=require

# JWT
JWT_SECRET=your-secret-key-at-least-32-chars
JWT_ACCESS_EXPIRY_MIN=15
JWT_REFRESH_EXPIRY_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback
OAUTH_STATE_SECRET=another-random-32-char-secret-key

# Resend (email)
RESEND_API_KEY=re_...
EMAIL_FROM_ADDR=noreply@proply.io
EMAIL_FROM_NAME=Proply

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_ID=price_...
STRIPE_PRICE_TEAM_ID=price_...

# Hetzner Object Storage (S3-compatible)
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=proply-media
S3_REGION=eu-central

# App URLs
APP_URL=http://localhost:5173
INTERNAL_URL=http://localhost:8080
