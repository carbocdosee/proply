# Compose-level variables for production.
# Copy to envs/prod/compose.env and fill before running prod-up.

# Docker images (built and pushed via CI)
BACKEND_IMAGE=ghcr.io/your-org/proply-backend:latest
FRONTEND_IMAGE=ghcr.io/your-org/proply-frontend:latest

# Ports exposed on the host (or reverse-proxy target)
BACKEND_PORT=8080
FRONTEND_PORT=3000

# VITE_API_URL — public-facing backend URL (baked into frontend bundle).
# This must match the URL browsers use to reach the API.
VITE_API_URL=https://api.proply.io
