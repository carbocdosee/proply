# Server
PORT=8080
ENV=development

# Database — points to postgres container inside proply-test network
DATABASE_URL=postgres://proply:proply@postgres:5432/proply?sslmode=disable

# JWT
JWT_SECRET=test-secret-key-at-least-32-chars-long!!
JWT_ACCESS_EXPIRY_MIN=15
JWT_REFRESH_EXPIRY_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback
OAUTH_STATE_SECRET=test-oauth-state-secret-at-least-32chars

# Email — Mailpit SMTP catcher (test stand only; set RESEND_API_KEY for production)
RESEND_API_KEY=
EMAIL_FROM_ADDR=noreply@proply.io
EMAIL_FROM_NAME=Proply
SMTP_HOST=mailpit
SMTP_PORT=1025

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_ID=
STRIPE_PRICE_TEAM_ID=

# Object Storage — MinIO (test stand); replace with Hetzner values for production
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=proply-media
S3_REGION=eu-central

# App URLs — frontend exposed on host :3000, backend on :8080
APP_URL=http://localhost:3000
INTERNAL_URL=http://backend:8080
