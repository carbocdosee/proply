# Compose-level variables — substituted into docker-compose.test.yml at runtime.
# These are NOT container env vars (those live in backend.env / frontend.env).

# Ports exposed on the host
BACKEND_PORT=8080
FRONTEND_PORT=3000

# VITE_API_URL is baked into the frontend bundle at build time.
# Must be a host-accessible address (browser calls this directly).
VITE_API_URL=http://localhost:8080
